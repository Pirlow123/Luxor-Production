{
  "name": "luxor-production",
  "version": "1.3.0",
  "description": "Luxor Production — Universal control interface for media servers, LED processors, PTZ cameras, network switches, lighting consoles, and intercom systems",
  "main": "electron-main.js",
  "author": "Luxor Productions",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux"
  },
  "dependencies": {
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.luxor.production",
    "productName": "Luxor Production",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "index.html",
      "css/**/*",
      "js/**/*",
      "assets/**/*",
      "mock-server.js",
      "node_modules/ws/**/*",
      "node_modules/xlsx/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/logos/luxor.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Luxor Production",
      "artifactName": "Luxor Production 1.3 setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/logos/luxor.png",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/logos/luxor.png"
    }
  }
}
